language = "c"
run = "gcc src/main.c src/digit_sum.c -o labrabota2-1 && ./labrabota2-1 10"

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Main"

[[workflows.workflow]]
name = "Run Main"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc src/main.c src/digit_sum.c -o hello && ./hello 5"
